{% import "_macros.html.jinja" as macros %}
{{ aoix.namespaces }}
{{ aoix.schema_ref }}
{{ aoix.periods }}
{{ aoix.defaults }}
{% set ns = namespace(fact_count = 0) %}
{% set timestamp = now_utc() %}
<!DOCTYPE html>
<html xml:lang="en"
  xmlns="http://www.w3.org/1999/xhtml"
  {{ '{{ namespaces }}' }}>
    <head>
        <!-- Generated by "{{ software.name | e }}" at {{ macros.render_datetime(timestamp) }} (using mireport version {{ software.version | e }}) -->
        <meta http-equiv="Content-Type" content="text/html; charset=UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1" />
        <title>{{ reportInfo.entityName | e }}&#8201;&#8212;&#8201;{{ reportInfo.title | e }}&#8201;&#8212;&#8201;{{ macros.render_duration_period_endyear(reportInfo.defaultPeriod) }}</title>
        <style type="text/css">
{% filter cssmin %}
{% include 'style-efrag.css.jinja' %}
{% endfilter %}
        </style>
    </head>
    <body class="theme-{{ theme }}">
        <div style="display:none">
            {{ '{{ header }}' }}
        </div>
        <!-- Cover Page -->
        <div class="page portrait-page cover-page">
            <div class="cover-top">
                <div class="cover-headline">
{% if reportInfo.entityName %}
                    <h2>{{ reportInfo.entityName | e }} </h2>
{% endif %}
{% if reportInfo.title %}
                    <h1>{{ reportInfo.title | e }} </h1>
{% endif %}
{% if reportInfo.defaultPeriod %}
                    <h2>{{ macros.render_duration_period_endyear(reportInfo.defaultPeriod) }}</h2>
{% endif %}
                </div>
{% if reportInfo.subtitle %}
                <div class="report-subtitle">
                    <h3>{{ reportInfo.subtitle | e }}</h3>
                </div>
{% endif %}
            </div>
{% if reportInfo.optionalCoverImage %}
            <div class="cover-image">
                <img src="{{ reportInfo.optionalCoverImage.as_data_url(max_width=500, max_height=500) }}" alt="Cover image" />
            </div>
{% endif %}
{% if reportInfo.optionalLogo %}
            <div class="company-logo">
                <img src="{{ reportInfo.optionalLogo.as_data_url(max_width=400) }}" alt="{{ reportInfo.entityName | e }} logo" />
            </div>
{% endif %}
        </div>
        <div class="page portrait-page doc-page" id="document-information">
            <div class="document-information">
                <h2>Document Information</h2>
                <dl class="document-info-list">
                    {% for item in documentInfo %}
                    <dt>{{ item.key | e }}</dt>
                    <dd>
                        {% if item.format_macro %}
                            {{ macros[item.format_macro](item.value) }}
                        {% else %}
                            {{ item.value | e }}
                        {% endif %}
                    </dd>
                    {% endfor %}
                    <dt>Report generated</dt>
                    <dd>{{ macros.render_datetime(timestamp) }}</dd>
                </dl>
                <div class="document-note">
                    <p>All disclosures are related to the reporting period above unless specified otherwise.</p>
                </div>
            </div>
        </div>
        <div class="page portrait-page toc-page" id="table-of-contents">
            <h1>Table of contents</h1>
            {#- Build ToC entries with their body-loop indices, then sort alphabetically -#}
            {% set toc_entries = [] %}
            {% for section in sections if section.hasFacts %}
                {% if toc_entries.append({'idx': loop.index, 'section': section}) %}{% endif %}
            {% endfor %}
            <ol class="toc-list">
{% set toc = namespace(current_prefix='') %}
{% for entry in toc_entries | sort(attribute='section.presentation.definition') %}
    {% set section = entry.section %}
    {% set prefix = macros.section_prefix(section) %}
    {% if prefix != toc.current_prefix %}
        {% if toc.current_prefix != '' %}
                    </ul>
                </li>
        {% endif %}
        {% set toc.current_prefix = prefix %}
                <li>
                    <span>[{{ macros.toc_short_prefix(section) }}] &#8212; {{ macros.toc_category(section) | e }}</span>
                    <ul>
    {% endif %}
    {% set subtitle = macros.toc_subtitle(section) %}
                        <li>
                            <a href="#section-class{{ entry.idx }}">
                                {{ (subtitle if subtitle else macros.toc_category(section)) | e }}
                            </a>
                        </li>
{% endfor %}
{% if toc.current_prefix != '' %}
                    </ul>
                </li>
{% endif %}
            </ol>
        </div>
{% set page = namespace(open=false, prefix='', css_class='') %}
{% set page_footnotes = [] %}
{% set page_fn_ids = [] %}
{% set fn_counter = namespace(num=0, page=0) %}
{% for section in sections if section.hasFacts %}
        {#- Compute this section's page-group key and page class -#}
        {% set current_prefix = macros.page_group(section) %}
        {% set current_class = macros.page_class_for_section(section) %}

        {% if section.style is sameas PresentationStyle.List %}
        {#- LIST SECTIONS: merge into same page when prefix and orientation match -#}
            {% if page.open and (current_prefix != page.prefix or current_class != page.css_class) %}
            {{ macros.render_page_footnotes(page_footnotes) }}
            {% if page_footnotes.clear() is none %}{% endif %}
            {% if page_fn_ids.clear() is none %}{% endif %}
            {% set fn_counter.num = 0 %}
        </div>
                {% set page.open = false %}
            {% endif %}
            {% if not page.open %}
        <div class="{{ current_class }}">
                {% set page.open = true %}
                {% set page.prefix = current_prefix %}
                {% set page.css_class = current_class %}
                {% set fn_counter.page = fn_counter.page + 1 %}
            {% endif %}

            {{ macros.create_h2_title(section, loop) }}

            <div class="fact-list">
            {% for rel, factList in section.relationshipToFact.items() %}
                {# Determine alternating shade suffix based on the loop index #}
                {% set shade = 'b' if loop.index0 is even else 'a' %}
                {% for fact in factList %}
                    {% set documentation = rel.concept.getDocumentationLabel() %}
                    <dl class="fact fact-depth-{{ rel.depth if rel.depth <= 4 else 4 }} fact-depth-{{ rel.depth if rel.depth <= 4 else 4 }}-{{ shade }}">
                        {% set _fn = footnotes_by_concept.get(rel.concept.qname | string) %}
                        <dt class="fact-value {% if fact.concept.isTextblock %}fact-textblock{% endif %}" title="{{ rel.concept.qname }}">{{ macros.render_fact_value(fact) }}{% if _fn and _fn.id not in page_fn_ids %}{% set fn_counter.num = fn_counter.num + 1 %}<a href="#fn-{{ fn_counter.page }}-{{ fn_counter.num }}" id="fnref-{{ fn_counter.page }}-{{ fn_counter.num }}"><sup class="footnote-ref">[{{ fn_counter.num }}]</sup></a>{% if page_footnotes.append({'fn': _fn, 'num': fn_counter.num, 'page': fn_counter.page}) is none %}{% endif %}{% if page_fn_ids.append(_fn.id) is none %}{% endif %}{% elif _fn %}<a href="#fn-{{ fn_counter.page }}-{{ page_footnotes | selectattr('fn.id', 'equalto', _fn.id) | map(attribute='num') | first }}"><sup class="footnote-ref">[{{ page_footnotes | selectattr('fn.id', 'equalto', _fn.id) | map(attribute='num') | first }}]</sup></a>{% endif %}{% set ns.fact_count = ns.fact_count + 1 %}</dt>
                        <dd class="fact-label">
                            <span {% if documentation != none %}class="hover-box"{% endif %}>
                                {{ macros.relationship_label(rel) | e }}
                                {% if documentation != none %}
                                <span class="tooltip">
                                    {{ documentation | e }}
                                </span>
                                {% endif %}
                            </span>
                        </dd>
                        {% if fact.hasNonDefaultPeriod %}
                        <dd class="fact-period">Reporting period: {{ macros.render_period(fact) }}</dd>
                        {% endif %}
                        {% set reference = none %}
                        {% if reference != none %}
                        <dd class="fact-ref">{{ documentation | e }}</dd>
                        {% endif %}
                    </dl>
                {% endfor %}
            {% endfor %}
            </div>

        {% elif section.style is sameas PresentationStyle.Table %}
        {#- TABLE SECTIONS: merge into same page when prefix and orientation match -#}
            {% if page.open and (current_prefix != page.prefix or current_class != page.css_class) %}
            {{ macros.render_page_footnotes(page_footnotes) }}
            {% if page_footnotes.clear() is none %}{% endif %}
            {% if page_fn_ids.clear() is none %}{% endif %}
            {% set fn_counter.num = 0 %}
        </div>
                {% set page.open = false %}
            {% endif %}
            {% if not page.open %}
        <div class="{{ current_class }}">
                {% set page.open = true %}
                {% set page.prefix = current_prefix %}
                {% set page.css_class = current_class %}
                {% set fn_counter.page = fn_counter.page + 1 %}
            {% endif %}

            {{ macros.create_h2_title(section, loop) }}

            <table class="thematic-table">
                <thead>
                {% for row in section.newColumnHeadings %}
                    {% set rowloop = loop %}
                    <tr>
                    {% for column in row %}
                        <th colspan="{{ column.colspan }}" rowspan="{{ column.rowspan }}" class="{% if column.numeric %}numeric{% elif section.numeric and not loop.first %}numeric{% elif not loop.first and rowloop.first and (row | count <= 2)  %}center{% else %}noop{% endif %}">
                        {% if column.value is none %}
                            {# nothing to do #}
                        {% elif column.value is string %}
                           {{ column.value | default("") }}
                        {% elif rowloop.first and column.isDuration %}
                            {{ macros.render_duration_period(column.value) }}
                        {% elif column.isDuration %}
                            {{ macros.render_duration_period_endyear(column.value) }}
                        {% elif column.isInstant %}
                            {{ macros.render_instant_period(column.value) }}
                        {% elif column.isConcept %}
                            {{ macros.concept_label(column.value) | e }}
                        {% elif column.isRelationship %}
                            {{ macros.relationship_label(column.value) | e }}
                        {% endif %}
                        </th>
                    {% endfor %}
                    </tr>
                {% endfor %}
                </thead>
                <tbody>
                    {% for row in section.data %}
                    <tr>
                        {% set rowHeading = section.rowHeadings[loop.index0] %}
                        {% if rowHeading is defined %}
                            {% set class = "numeric-row" if section.numeric else "row" %}
                        <th class="{{ class }}">
                            {% if rowHeading.value is string %}
                                {{ rowHeading.value | e }}
                            {% elif rowHeading.isConcept %}
                                {{ macros.concept_label(rowHeading.value) | e }}
                            {% elif rowHeading.isRelationship %}
                                {{ macros.relationship_label(rowHeading.value) | e }}
                            {% endif %}
                        </th>
                        {% endif %}
                        {% for fact in row %}
                            {% if fact is none %}
                        <td></td>
                            {% else %}
                        {% set _fn = footnotes_by_concept.get(fact.concept.qname | string) %}
                        <td {% if fact.concept.isNumeric%}class="numeric"{% endif %}>
                        {{ macros.render_fact_value(fact, section.unitSymbol or section.columnHasUnit(loop.index0)) }}{% if _fn and _fn.id not in page_fn_ids %}{% set fn_counter.num = fn_counter.num + 1 %}<a href="#fn-{{ fn_counter.page }}-{{ fn_counter.num }}" id="fnref-{{ fn_counter.page }}-{{ fn_counter.num }}"><sup class="footnote-ref">[{{ fn_counter.num }}]</sup></a>{% if page_footnotes.append({'fn': _fn, 'num': fn_counter.num, 'page': fn_counter.page}) is none %}{% endif %}{% if page_fn_ids.append(_fn.id) is none %}{% endif %}{% elif _fn %}<a href="#fn-{{ fn_counter.page }}-{{ page_footnotes | selectattr('fn.id', 'equalto', _fn.id) | map(attribute='num') | first }}"><sup class="footnote-ref">[{{ page_footnotes | selectattr('fn.id', 'equalto', _fn.id) | map(attribute='num') | first }}]</sup></a>{% endif %}{% set ns.fact_count = ns.fact_count + 1 %}
                        </td>
                            {% endif %}
                        {% endfor %}
                    </tr>
                    {% endfor %}
                </tbody>
            </table>
        {% else %}
        {#- UNSUPPORTED STYLES: always get their own page -#}
            {% if page.open %}
            {{ macros.render_page_footnotes(page_footnotes) }}
            {% if page_footnotes.clear() is none %}{% endif %}
            {% if page_fn_ids.clear() is none %}{% endif %}
            {% set fn_counter.num = 0 %}
        </div>
                {% set page.open = false %}
            {% endif %}
        <div class="page portrait-page">
            <h2>{{ macros.section_label(section) | e }}</h2>
            <pre>Unsupported presentation style. [{{section.style.name}}{% if section.tabular %}, {{ section.tableStyle.name }}{% endif %}]</pre>
        </div>
            {% set page.prefix = '' %}
            {% set page.css_class = '' %}
        {% endif %}
{% endfor %}
        {#- Close the last page div if still open -#}
        {% if page.open %}
        {{ macros.render_page_footnotes(page_footnotes) }}
        </div>
        {% endif %}
  <!-- Final Page -->
  <div class="page portrait-page footer-page">
    <p>This report contains {{ ns.fact_count }} XBRL facts{% if ns.fact_count != uniqueFactCount %} (generated from {{ uniqueFactCount }} unique input facts){% endif %}.</p>
  </div>

</body>
</html>
  
   
   
